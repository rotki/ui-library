{
  "name": "@rotki/ui-library",
  "version": "2.18.0",
  "description": "A vue design system and component library for rotki",
  "type": "module",
  "keywords": [
    "vue",
    "ui",
    "components",
    "rotki"
  ],
  "license": "AGPL-3.0",
  "homepage": "https://github.com/rotki/ui-library#readme",
  "bugs": {
    "url": "https://github.com/rotki/ui-library/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rotki/ui-library.git"
  },
  "author": "Rotki Solutions GmbH <info@rotki.com>",
  "files": [
    "/dist"
  ],
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme/index.js",
      "default": "./dist/theme/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js",
      "default": "./dist/components/index.js"
    },
    "./composables": {
      "types": "./dist/composables/index.d.ts",
      "import": "./dist/composables/index.js",
      "default": "./dist/composables/index.js"
    },
    "./style.css": {
      "default": "./dist/style.css"
    },
    "./vite-plugin": {
      "types": "./dist/vite-plugin/index.d.ts",
      "import": "./dist/vite-plugin/index.js",
      "default": "./dist/vite-plugin/index.js"
    },
    "./vite-plugin/client": {
      "types": "./dist/vite-plugin/client.d.ts"
    }
  },
  "typesVersions": {
    "*": {
      "theme": [
        "./dist/theme/index.d.ts"
      ],
      "composables": [
        "./dist/composables/index.d.ts"
      ],
      "components": [
        "./dist/components/index.d.ts"
      ],
      "vite-plugin": [
        "./dist/vite-plugin/index.d.ts"
      ],
      "vite-plugin/client": [
        "./dist/vite-plugin/client.d.ts"
      ]
    }
  },
  "scripts": {
    "build:prod": "tsx scripts/dist-build.mjs",
    "build": "pnpm run generate-icons && vite build && cp ../../README.md dist/ && cp src/vite-plugin/client.d.ts dist/vite-plugin/",
    "build:storybook": "STORYBOOK=true storybook build",
    "build:tailwind": "tailwindcss -o dist/style.css --minify",
    "build:types": "vue-tsc -p tsconfig.build.json",
    "build:web-types": "tsx scripts/build-web-types.mjs",
    "generate-icons": "tsx scripts/generate-icons.mjs",
    "resolve:alias": "tsc-alias --replacer ./scripts/tsc-alias-replacer.cjs -p tsconfig.build.json --dir dist",
    "verify:dist": "tsx scripts/verify-dist.ts",
    "dev": "vite",
    "prepare": "node scripts/prepare.mjs",
    "storybook": "storybook dev -p 6006",
    "test": "vitest --ui --project=unit",
    "test:run": "vitest run --project=unit",
    "test:ci": "vitest run --project=unit",
    "test:storybook": "vitest run --project=storybook",
    "test:unit": "vitest run --project=unit",
    "coverage": "pnpm run coverage:unit && pnpm run coverage:storybook && pnpm run coverage:merge",
    "coverage:unit": "vitest run --project=unit --reporter=blob --outputFile=tests/.vitest-reports/unit.json --coverage",
    "coverage:storybook": "vitest run --project=storybook --reporter=blob --outputFile=tests/.vitest-reports/storybook.json --coverage",
    "coverage:merge": "vitest --merge-reports=tests/.vitest-reports --coverage",
    "coverage:preview": "npx vite preview --open --outDir tests/coverage",
    "typecheck": "vue-tsc --noEmit && vue-tsc --noEmit -p tsconfig.vitest.json",
    "new": "tsx scripts/new-story.ts"
  },
  "peerDependencies": {
    "dayjs": ">=1.11.13 <12",
    "vue": ">=3.5.0",
    "vue-router": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vue-router": {
      "optional": true
    }
  },
  "web-types": "dist/web-types.json",
  "dependencies": {
    "@floating-ui/dom": "catalog:",
    "@vueuse/core": "catalog:",
    "@vueuse/shared": "catalog:",
    "scule": "catalog:",
    "tailwind-merge": "catalog:",
    "tailwind-variants": "catalog:",
    "tinycolor2": "catalog:"
  },
  "devDependencies": {
    "@fontsource/roboto": "catalog:",
    "@storybook/addon-a11y": "catalog:",
    "@storybook/addon-docs": "catalog:",
    "@storybook/addon-links": "catalog:",
    "@storybook/addon-themes": "catalog:",
    "@storybook/addon-vitest": "catalog:",
    "@storybook/vue3-vite": "catalog:",
    "@tsconfig/node24": "catalog:",
    "@types/node": "catalog:",
    "@types/tinycolor2": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vitest/browser": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "@vue/test-utils": "catalog:",
    "@vue/tsconfig": "catalog:",
    "autoprefixer": "catalog:",
    "cac": "catalog:",
    "consola": "catalog:",
    "fast-glob": "catalog:",
    "fast-xml-parser": "catalog:",
    "fs-extra": "catalog:",
    "happy-dom": "catalog:",
    "lucide": "catalog:",
    "msw": "catalog:",
    "postcss": "catalog:",
    "storybook": "catalog:",
    "tailwindcss": "catalog:",
    "tsc-alias": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "unplugin-auto-import": "catalog:",
    "vite": "catalog:",
    "vite-plugin-vue-devtools": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:",
    "vue-component-meta": "catalog:",
    "vue-router": "catalog:",
    "vue-tsc": "catalog:"
  },
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10 <11"
  }
}
