{
  "name": "example",
  "version": "2.14.1",
  "private": true,
  "scripts": {
    "dev": "vite --open",
    "build": "pnpm typecheck && pnpm build:app",
    "build:app": "vite build",
    "build:preview": "pnpm build:app && pnpm preview",
    "preview": "vite preview",
    "typecheck": "vue-tsc --build --noEmit",
    "test:e2e": "pnpm build:app && playwright test",
    "test:e2e:dev": "DEV=true playwright test",
    "test:e2e:ui": "DEV=true playwright test --ui"
  },
  "dependencies": {
    "@rotki/ui-library": "workspace:*",
    "pinia": "3.0.4",
    "tailwindcss": "3.4.19",
    "vue": "3.5.30",
    "vue-i18n": "11.3.0",
    "vue-router": "5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@tsconfig/node24": "24.0.4",
    "@types/node": "24.12.0",
    "@vitejs/plugin-vue": "6.0.5",
    "@vue/tsconfig": "0.9.0",
    "autoprefixer": "10.4.27",
    "postcss": "8.5.8",
    "typescript": "5.9.3",
    "unplugin-auto-import": "21.0.0",
    "vite": "7.3.1",
    "vue-tsc": "3.2.5"
  }
}
