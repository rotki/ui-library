{
  "name": "@rotki/ui-library-monorepo",
  "version": "2.19.3",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "A vue design system and component library for rotki - monorepo root",
  "type": "module",
  "license": "AGPL-3.0",
  "homepage": "https://github.com/rotki/ui-library#readme",
  "bugs": {
    "url": "https://github.com/rotki/ui-library/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rotki/ui-library.git"
  },
  "author": "Rotki Solutions GmbH <info@rotki.com>",
  "scripts": {
    "build:prod": "pnpm --filter @rotki/ui-library build:prod",
    "build": "pnpm --filter @rotki/ui-library build",
    "build:storybook": "pnpm --filter @rotki/ui-library build:storybook",
    "dev": "pnpm --filter @rotki/ui-library dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "storybook": "pnpm --filter @rotki/ui-library storybook",
    "test": "pnpm --filter @rotki/ui-library test",
    "test:run": "pnpm --filter @rotki/ui-library test:run",
    "test:ci": "pnpm --filter @rotki/ui-library test:ci",
    "test:e2e": "pnpm --filter example test:e2e",
    "test:e2e:dev": "pnpm --filter example test:e2e:dev",
    "test:e2e:ui": "pnpm --filter example test:e2e:ui",
    "test:visual": "pnpm --filter example test:visual",
    "test:visual:update": "pnpm --filter example test:visual:update",
    "test:storybook": "pnpm --filter @rotki/ui-library test:storybook",
    "test:all": "pnpm test:run && pnpm test:e2e",
    "coverage": "pnpm --filter @rotki/ui-library coverage",
    "coverage:unit": "pnpm --filter @rotki/ui-library coverage:unit",
    "coverage:storybook": "pnpm --filter @rotki/ui-library coverage:storybook",
    "coverage:merge": "pnpm --filter @rotki/ui-library coverage:merge",
    "coverage:preview": "pnpm --filter @rotki/ui-library coverage:preview",
    "typecheck": "pnpm --filter @rotki/ui-library typecheck && pnpm --filter example typecheck",
    "prepare": "husky",
    "release": "bumpp -r --no-push",
    "new": "pnpm --filter @rotki/ui-library new"
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@rotki/eslint-config": "catalog:",
    "@rotki/eslint-plugin": "catalog:",
    "@tsconfig/node24": "catalog:",
    "bumpp": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-storybook": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10 <11"
  },
  "lint-staged": {
    "*.{js,cjs,ts,vue,yml,json,md}": "eslint"
  }
}
